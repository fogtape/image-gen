# AI Image Studio runtime configuration
# Copy this file to .env for local/Docker deployments.

IMAGE_GEN_ADMIN_TOKEN=""
IMAGE_GEN_DEFAULT_API_URL="https://api.openai.com"
IMAGE_GEN_DEFAULT_IMAGE_MODEL="gpt-image-2"
IMAGE_GEN_DEFAULT_RESPONSES_MODEL="gpt-5.4"
IMAGE_GEN_DEFAULT_STREAM_MODE=false
IMAGE_GEN_DEFAULT_RESPONSES_AUTO_FALLBACK=true
IMAGE_GEN_DEFAULT_IMAGE_EDITS_COMPAT_MODE=false
IMAGE_GEN_FORCE_PROXY=false
IMAGE_GEN_DEFAULT_SIZE="auto"
IMAGE_GEN_DEFAULT_QUALITY="medium"
IMAGE_GEN_DEFAULT_FORMAT="png"
IMAGE_GEN_DEFAULT_BACKGROUND="auto"
IMAGE_GEN_WATERMARK_ENABLED=false
IMAGE_GEN_WATERMARK_TEMPORARY_MODE="default"
IMAGE_GEN_WATERMARK_MODE="camera-time"
IMAGE_GEN_WATERMARK_TEXT="AI Image Studio"
IMAGE_GEN_WATERMARK_TIME_FORMAT="camera"
IMAGE_GEN_WATERMARK_POSITION="bottom-right"
IMAGE_GEN_WATERMARK_OPACITY=0.72
IMAGE_GEN_WATERMARK_FONT_SIZE=28
IMAGE_GEN_WATERMARK_COLOR="#ffffff"
IMAGE_GEN_WATERMARK_SHADOW=true
IMAGE_GEN_WATERMARK_BACKGROUND=true
IMAGE_GEN_STORAGE_ENABLED=true
IMAGE_GEN_PROMPT_ENHANCEMENT_ENABLED=false
IMAGE_GEN_PROMPT_ENHANCEMENT_RUN_MODE="manual"
IMAGE_GEN_PROMPT_ENHANCEMENT_MODEL=""
IMAGE_GEN_PROMPT_ENHANCEMENT_MODE="balanced"
IMAGE_GEN_PROMPT_ENHANCEMENT_LANGUAGE="auto"
IMAGE_GEN_DEPLOY_PLATFORM="node"
IMAGE_GEN_DEPLOY_ACCOUNT_ID=""
IMAGE_GEN_DEPLOY_PROJECT_ID=""
IMAGE_GEN_DEPLOY_API_TOKEN=""
IMAGE_GEN_DEPLOY_AUTO_SYNC=false
IMAGE_GEN_DEPLOY_AUTO_REDEPLOY=false
